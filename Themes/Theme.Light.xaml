<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <BitmapImage x:Key="Image.AppLogo" UriSource="/Assets/smartitecture-light.png" />

    <!-- Core colors -->
    <Color x:Key="Color.Primary">#4F46E5</Color>
    <Color x:Key="Color.Secondary">#7C3AED</Color>
    <Color x:Key="Color.Success">#059669</Color>
    <Color x:Key="Color.Warning">#D97706</Color>
    <Color x:Key="Color.Error">#DC2626</Color>
    <Color x:Key="Color.Surface">#FFFFFF</Color>
    <Color x:Key="Color.OnSurface">#0B1220</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="Brush.Primary" Color="{StaticResource Color.Primary}"/>
    <SolidColorBrush x:Key="Brush.Secondary" Color="{StaticResource Color.Secondary}"/>
    <SolidColorBrush x:Key="Brush.Success" Color="{StaticResource Color.Success}"/>
    <SolidColorBrush x:Key="Brush.Warning" Color="{StaticResource Color.Warning}"/>
    <SolidColorBrush x:Key="Brush.Error" Color="{StaticResource Color.Error}"/>
    <SolidColorBrush x:Key="Brush.Surface" Color="{StaticResource Color.Surface}"/>
    <SolidColorBrush x:Key="Brush.OnSurface" Color="{StaticResource Color.OnSurface}"/>
    <SolidColorBrush x:Key="Brush.MutedText" Color="#1F2937"/>
    <SolidColorBrush x:Key="Brush.CaptionText" Color="#334155"/>

    <SolidColorBrush x:Key="Brush.ButtonPrimaryForeground" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="Brush.ButtonGlassForeground" Color="#0B1220"/>

    <SolidColorBrush x:Key="Brush.GlassButtonBackground" Color="#DDE7FF"/>
    <SolidColorBrush x:Key="Brush.GlassButtonBorder" Color="#B8C7FF"/>
    <SolidColorBrush x:Key="Brush.GlassButtonHoverBackground" Color="#CFE0FF"/>

    <SolidColorBrush x:Key="Brush.PlaceholderText" Color="#64748B"/>
    <SolidColorBrush x:Key="Brush.InputBackground" Color="#F8FAFC"/>
    <SolidColorBrush x:Key="Brush.InputBorder" Color="#CBD5E1"/>

    <!-- Background gradient (window) -->
    <LinearGradientBrush x:Key="Brush.AppBackground" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#F8FAFF" Offset="0"/>
        <GradientStop Color="#EEF3FF" Offset="0.35"/>
        <GradientStop Color="#DDE7FF" Offset="1"/>
    </LinearGradientBrush>

    <!-- Glass/Translucent surfaces -->
    <LinearGradientBrush x:Key="Brush.GlassCard" StartPoint="0,0" EndPoint="1,1" Opacity="0.96">
        <GradientStop Color="#CCFFFFFF" Offset="0"/>
        <GradientStop Color="#B3FFFFFF" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="Brush.GlassBorder" StartPoint="0,0" EndPoint="1,1" Opacity="0.95">
        <GradientStop Color="#66FFFFFF" Offset="0"/>
        <GradientStop Color="#33FFFFFF" Offset="1"/>
    </LinearGradientBrush>

    <!-- Skeleton brush -->
    <LinearGradientBrush x:Key="Brush.Skeleton" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#220B1220" Offset="0"/>
        <GradientStop Color="#330B1220" Offset="0.5"/>
        <GradientStop Color="#220B1220" Offset="1"/>
    </LinearGradientBrush>
</ResourceDictionary>
