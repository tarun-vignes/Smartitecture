<Window x:Class="SmartitectureSimple.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Height="680"
        Width="980"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.AppBackground}"
        FontFamily="Segoe UI Variable Text, Segoe UI, Arial"
        Foreground="{DynamicResource Brush.OnSurface}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Settings" Style="{StaticResource Text.H2}" VerticalAlignment="Center"/>
            <Button Grid.Column="1" Content="Close" Style="{StaticResource Button.Glass}" Padding="10,6" Click="Close_Click"/>
        </Grid>

        <Frame Grid.Row="1"
               x:Name="SettingsFrame"
               NavigationUIVisibility="Hidden"
               Background="Transparent"/>
    </Grid>
</Window>
