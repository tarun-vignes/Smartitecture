<Page x:Class="Smartitecture.UI.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource Brush.AppBackground}"
      FontFamily="Segoe UI Variable Text, Segoe UI, Arial"
      Foreground="{DynamicResource Brush.OnSurface}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="&#x2190; Getting Started"
                    Style="{StaticResource Button.Glass}"
                    Padding="10,6"
                    Margin="0,2,14,0"
                    VerticalAlignment="Top"
                    Click="BackToGettingStarted_Click"/>

            <StackPanel Grid.Column="1">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,4">
                    <Image Source="{DynamicResource Image.AppLogo}" Width="28" Height="28" Stretch="Uniform" Margin="0,0,10,0"/>
                    <TextBlock x:Name="GreetingText" Text="Welcome" Style="{StaticResource Text.H1}"/>
                </StackPanel>
                <TextBlock Text="Dashboard"
                           Style="{StaticResource Text.Body}"
                           FontSize="16"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top">
                <TextBlock Text="Theme:" Style="{StaticResource Text.Caption}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox x:Name="ThemeSelector" Width="160" SelectionChanged="ThemeSelector_SelectionChanged">
                    <ComboBoxItem Content="System" IsSelected="True"/>
                    <ComboBoxItem Content="Dark"/>
                    <ComboBoxItem Content="Light"/>
                </ComboBox>
            </StackPanel>
        </Grid>

        <!-- Main -->
        <Border Grid.Row="1" Style="{StaticResource Card.Glass}" Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Quick Start"
                           Style="{StaticResource Text.H2}"
                           Margin="0,0,0,6"/>

                <TextBlock Grid.Row="1"
                           Text="Start a chat to ask questions, automate tasks, or run diagnostics."
                           Style="{StaticResource Text.Body}"
                           Margin="0,0,0,14"/>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource Card.Glass}" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="Chat" Style="{StaticResource Text.H2}" />
                            <TextBlock Text="Ask anything and get help." Style="{StaticResource Text.Caption}" Margin="0,4,0,10"/>
                            <Button Content="Open Chat &#x2192;" Style="{StaticResource Button.Primary}" Click="OpenChat_Click" Width="150"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource Card.Glass}" Margin="10,0,0,0">
                        <StackPanel>
                            <TextBlock Text="Status" Style="{StaticResource Text.H2}" />
                            <TextBlock x:Name="StatusText"
                                       Text="Navigation + theme are wired. Next: expand dashboard widgets."
                                       Style="{StaticResource Text.Caption}"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <!-- Footer -->
        <TextBlock Grid.Row="2"
                   Text="Tip: Choose “System” to follow Windows theme automatically."
                   Style="{StaticResource Text.Caption}"
                   Opacity="0.9"
                   HorizontalAlignment="Center"
                   Margin="0,14,0,0"/>
    </Grid>
</Page>
