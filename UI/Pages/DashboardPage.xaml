<Page x:Class="Smartitecture.UI.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource Brush.AppBackground}"
      FontFamily="Segoe UI Variable Text, Segoe UI, Arial"
      Foreground="{DynamicResource Brush.OnSurface}">

    <Grid Margin="24">
        <StackPanel>
            <TextBlock x:Name="GreetingText" Text="Dashboard" Style="{StaticResource Text.H1}"/>
            <TextBlock Text="Quick actions and status." Style="{StaticResource Text.Caption}" Margin="0,6,0,0"/>

            <Grid Margin="0,18,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource Card.Glass}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="Chat" Style="{StaticResource Text.H2}"/>
                        <TextBlock Text="Ask questions, automate tasks, or run diagnostics." Style="{StaticResource Text.Caption}" TextWrapping="Wrap" Margin="0,6,0,12"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Open chat" Style="{StaticResource Button.Primary}" Width="140" Click="OpenChat_Click"/>
                            <Button Content="Settings" Style="{StaticResource Button.Glass}" Width="120" Margin="10,0,0,0" Click="OpenSettings_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource Card.Glass}" Margin="10,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Status" Style="{StaticResource Text.H2}"/>

                        <StackPanel Margin="0,8,0,0">
                            <TextBlock x:Name="AiStatusText" Style="{StaticResource Text.Caption}" TextWrapping="Wrap"/>
                            <TextBlock x:Name="ModelStatusText" Style="{StaticResource Text.Caption}" Margin="0,4,0,0"/>
                        </StackPanel>

                        <Button Content="Setup &amp; health check" Style="{StaticResource Button.Glass}" Margin="0,12,0,0" Click="OpenSetup_Click"/>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </Grid>
</Page>
