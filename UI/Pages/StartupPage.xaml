<Page x:Class="Smartitecture.UI.Pages.StartupPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource Brush.AppBackground}"
      FontFamily="Segoe UI Variable Text, Segoe UI, Arial"
      Foreground="{DynamicResource Brush.OnSurface}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="Setup &amp; Health Check" Style="{StaticResource Text.H1}"/>
            <TextBlock Text="Make sure keys and core system checks are ready." Style="{StaticResource Text.Caption}" Margin="0,6,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Card.Glass}" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="Readiness" Style="{StaticResource Text.H2}"/>

                    <StackPanel Margin="0,10,0,0">
                        <TextBlock Text="AI keys" Style="{StaticResource Text.Caption}"/>
                        <TextBlock x:Name="ConfigStatusText" Style="{StaticResource Text.Warning}" Margin="0,4,0,0"/>

                        <TextBlock Text="Windows Defender" Style="{StaticResource Text.Caption}" Margin="0,12,0,0"/>
                        <TextBlock x:Name="DefenderStatusText" Style="{StaticResource Text.Warning}" Margin="0,4,0,0"/>

                        <TextBlock Text="Firewall" Style="{StaticResource Text.Caption}" Margin="0,12,0,0"/>
                        <TextBlock x:Name="FirewallStatusText" Style="{StaticResource Text.Warning}" Margin="0,4,0,0"/>

                        <TextBlock Text="Overall" Style="{StaticResource Text.Caption}" Margin="0,12,0,0"/>
                        <TextBlock x:Name="OverallStatusText" Style="{StaticResource Text.Warning}" Margin="0,4,0,0"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                        <Button Content="Refresh" Style="{StaticResource Button.Glass}" Click="Refresh_Click" Width="120"/>
                        <Button Content="Open settings" Style="{StaticResource Button.Primary}" Click="OpenSettings_Click" Width="150" Margin="10,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource Card.Glass}" Margin="10,0,0,0">
                <StackPanel>
                    <TextBlock Text="Next" Style="{StaticResource Text.H2}"/>
                    <TextBlock Text="Once you're ready, jump into chat." Style="{StaticResource Text.Caption}" TextWrapping="Wrap" Margin="0,6,0,12"/>
                    <Button Content="Go to dashboard" Style="{StaticResource Button.Glass}" Click="GoDashboard_Click"/>
                    <Button Content="Go to chat" Style="{StaticResource Button.Primary}" Click="GoChat_Click" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
