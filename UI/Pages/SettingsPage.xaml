<Page x:Class="Smartitecture.UI.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource Brush.AppBackground}"
      FontFamily="Segoe UI Variable Text, Segoe UI, Arial"
      Foreground="{DynamicResource Brush.OnSurface}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,10">
                <TextBlock Text="Settings" Style="{StaticResource Text.H1}"/>
                <TextBlock Text="Theme, AI providers, and app preferences." Style="{StaticResource Text.Caption}" Margin="0,4,0,0"/>
            </StackPanel>

            <StackPanel Grid.Row="1">
                <Border Style="{StaticResource Card.Glass}">
                    <StackPanel>
                        <TextBlock Text="Appearance" Style="{StaticResource Text.H2}"/>

                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="Theme" Style="{StaticResource Text.Caption}" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1" x:Name="ThemeSelector" Style="{StaticResource Input.ComboBox}" SelectionChanged="ThemeSelector_SelectionChanged">
                                <ComboBoxItem Content="System"/>
                                <ComboBoxItem Content="Dark"/>
                                <ComboBoxItem Content="Light"/>
                            </ComboBox>
                        </Grid>

                        <CheckBox x:Name="NotificationsToggle" Content="Enable notifications" Style="{StaticResource Input.CheckBox}" Margin="0,12,0,0" Checked="NotificationsToggle_Changed" Unchecked="NotificationsToggle_Changed"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card.Glass}">
                    <StackPanel>
                        <TextBlock Text="AI" Style="{StaticResource Text.H2}"/>

                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="Current model" Style="{StaticResource Text.Caption}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" x:Name="CurrentModelText" Style="{StaticResource Text.Body}" VerticalAlignment="Center"/>
                        </Grid>

                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="Switch model" Style="{StaticResource Text.Caption}" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1" x:Name="ModelSelector" Style="{StaticResource Input.ComboBox}" SelectionChanged="ModelSelector_SelectionChanged"/>
                        </Grid>

                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="OpenAI" Style="{StaticResource Text.Caption}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" x:Name="OpenAiStatusText" Style="{StaticResource Text.Warning}" VerticalAlignment="Center"/>
                        </Grid>

                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="Claude" Style="{StaticResource Text.Caption}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" x:Name="ClaudeStatusText" Style="{StaticResource Text.Warning}" VerticalAlignment="Center"/>
                        </Grid>

                        <Border Background="{DynamicResource Brush.GlassButtonBackground}"
                                BorderBrush="{DynamicResource Brush.GlassButtonBorder}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="12"
                                Margin="0,12,0,0">
                            <StackPanel>
                                <TextBlock Text="API keys" Style="{StaticResource Text.Body}" FontWeight="SemiBold"/>
                                <TextBlock Text="Saved locally to your user profile (AppData). You can also use env vars OPENAI_API_KEY and ANTHROPIC_API_KEY." Style="{StaticResource Text.Caption}" TextWrapping="Wrap" Margin="0,4,0,10"/>

                                <TextBlock Text="OpenAI API key" Style="{StaticResource Text.Caption}"/>
                                <PasswordBox x:Name="OpenAiKeyBox" Style="{StaticResource Input.PasswordBox}" Margin="0,4,0,0"/>

                                <TextBlock Text="Anthropic (Claude) API key" Style="{StaticResource Text.Caption}" Margin="0,10,0,0"/>
                                <PasswordBox x:Name="ClaudeKeyBox" Style="{StaticResource Input.PasswordBox}" Margin="0,4,0,0"/>

                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                    <Button Content="Save keys" Style="{StaticResource Button.Primary}" Click="SaveKeys_Click"/>
                                    <Button Content="Clear stored keys" Style="{StaticResource Button.Glass}" Margin="10,0,0,0" Click="ClearKeys_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card.Glass}">
                    <StackPanel>
                        <TextBlock Text="System" Style="{StaticResource Text.H2}"/>
                        <CheckBox x:Name="AutoStartToggle" Content="Start with Windows" Style="{StaticResource Input.CheckBox}" Margin="0,12,0,0" Checked="AutoStartToggle_Changed" Unchecked="AutoStartToggle_Changed"/>
                        <TextBlock Text="This toggles the current user Run key." Style="{StaticResource Text.Caption}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <TextBlock x:Name="SaveStatusText" Style="{StaticResource Text.Caption}" Opacity="0.9" Margin="12,6,12,0"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
